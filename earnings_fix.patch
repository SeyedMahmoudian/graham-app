diff --git a/codes/graham.py b/codes/graham.py
--- a/codes/graham.py
+++ b/codes/graham.py
@@ -45,7 +45,7 @@
-    eps_hist  = sec.get("eps",      [])
+    earnings_hist = sec.get("earnings", [])

-    eps       = _safe(_first(eps_hist))
+    earnings   = _safe(_first(earnings_hist))

@@ -72,8 +72,10 @@
     eq        = _safe(_first(equity))
     sh        = _safe(_first(shares))

-    pe = _safe(price / eps)  if price and eps  and eps  > 0 else None
+    eps = (earnings / sh) if earnings and sh and sh > 0 else None
+    pe = _safe(price / eps) if price and eps and eps > 0 else None

@@ -110,8 +112,10 @@
-    eps_values = [r["value"] for r in eps_hist if r["value"] is not None]
+    eps_values = [
+        _safe(r["value"]) / _safe(_first(shares))
+        for r in earnings_hist if r.get("value") is not None
+    ]

